---
import Layout from "@/layouts/Layout.astro"
---

<Layout
	title="API Reference - Coming Soon"
	description="Programmatic access to Hazel is coming soon. Build integrations, automate workflows, and extend Hazel with our upcoming REST API."
>
	<section class="w-full relative min-h-[calc(100vh-4rem)]">
		<div class="relative flex flex-col items-center w-full px-6">
			<!-- Background gradient -->
			<div class="absolute inset-0">
				<div
					class="absolute inset-0 -z-10 h-[520px] w-full [background:radial-gradient(125%_125%_at_50%_10%,var(--background)_40%,var(--secondary)_100%)] rounded-b-xl opacity-40"
				>
				</div>
			</div>

			<div
				class="relative z-10 pt-32 pb-20 max-w-3xl mx-auto h-full w-full flex flex-col gap-8 items-center justify-center"
			>
				<!-- Coming Soon Badge -->
				<p
					class="border border-secondary/30 bg-secondary/10 backdrop-blur-sm rounded-full text-sm h-9 px-4 flex items-center gap-2 font-mono text-secondary"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="size-4"
					>
						<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
						></path>
						<path
							d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
						></path>
						<path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"></path>
						<path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path>
					</svg>
					Coming Soon
				</p>

				<!-- Title & Description -->
				<div class="flex flex-col items-center justify-center gap-5">
					<h1
						class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tighter text-balance text-center text-primary"
					>
						API Reference
					</h1>
					<p
						class="text-base md:text-lg text-center text-muted-foreground font-medium text-balance leading-relaxed tracking-tight max-w-xl"
					>
						Programmatic access to Hazel is on the way. Build custom integrations, automate
						workflows, and extend Hazel's capabilities with our upcoming REST API.
					</p>
				</div>

				<!-- Decorative Code Preview -->
				<div
					class="w-full max-w-lg mt-4 rounded-xl border border-border bg-accent/50 backdrop-blur-sm overflow-hidden shadow-2xl shadow-secondary/5"
				>
					<!-- Terminal Header -->
					<div class="flex items-center gap-2 px-4 py-3 border-b border-border bg-accent/80">
						<div class="flex items-center gap-1.5">
							<div class="size-3 rounded-full bg-red-500/80"></div>
							<div class="size-3 rounded-full bg-yellow-500/80"></div>
							<div class="size-3 rounded-full bg-green-500/80"></div>
						</div>
						<span class="text-xs text-muted-foreground font-mono ml-2">api.hazel.sh</span>
					</div>

					<!-- Code Content -->
					<div class="p-5 font-mono text-sm leading-relaxed">
						<div class="flex items-center gap-2 text-muted-foreground">
							<span class="text-green-400">GET</span>
							<span class="text-primary">/v1/conversations</span>
						</div>
						<div class="mt-1 text-muted-foreground/60 text-xs">
							Authorization: Bearer sk_live_•••••••
						</div>

						<div class="mt-5 pt-4 border-t border-border/50">
							<span class="text-muted-foreground/60 text-xs">Response</span>
							<pre
								class="mt-2 text-xs"><code class="text-muted-foreground"><span class="text-primary">{"{"}</span>
  <span class="text-secondary">"conversations"</span>: [...],
  <span class="text-secondary">"has_more"</span>: <span class="text-green-400">true</span>,
  <span class="text-secondary">"next_cursor"</span>: <span class="text-primary">"cur_abc123"</span>
<span class="text-primary">{"}"}</span></code></pre>
						</div>
					</div>
				</div>

				<!-- CTA Buttons -->
				<div class="flex items-center gap-3 flex-wrap justify-center mt-4">
					<a
						href="https://github.com/hazelchat/hazel"
						target="_blank"
						rel="noopener noreferrer"
						class="h-10 flex items-center justify-center gap-2 px-5 text-sm font-medium tracking-wide text-primary rounded-full transition-all ease-out duration-200 active:scale-95 bg-background border border-border hover:border-muted-foreground/50 hover:bg-accent/50"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="16"
							height="16"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="size-4"
						>
							<path
								d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
							></path>
							<path d="M9 18c-4.51 2-5-2-7-2"></path>
						</svg>
						Star on GitHub
					</a>
					<a
						href="/changelog"
						class="h-10 flex items-center justify-center gap-2 px-5 text-sm font-medium tracking-wide text-primary rounded-full transition-all ease-out duration-200 active:scale-95 bg-background border border-border hover:border-muted-foreground/50 hover:bg-accent/50"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="16"
							height="16"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="size-4"
						>
							<path d="M12 8V4H8"></path>
							<rect width="16" height="12" x="4" y="8" rx="2"></rect>
							<path d="M2 14h2"></path>
							<path d="M20 14h2"></path>
							<path d="M15 13v2"></path>
							<path d="M9 13v2"></path>
						</svg>
						View Changelog
					</a>
				</div>

				<!-- Subtle Note -->
				<p class="text-xs text-muted-foreground/60 text-center mt-2">
					Follow our changelog for API release updates
				</p>
			</div>
		</div>
	</section>
</Layout>
