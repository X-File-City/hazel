---
import { siteConfig } from "@/lib/config";
import { Marquee } from "@/components/ui/marquee";
import { GitHubCTAButton } from "@/components/react/GitHubCTAButton";
// import { HeroVideoDialog } from "@/components/react/HeroVideoDialog";

const { hero } = siteConfig;

const features = [
  "Real-Time Messaging - Never miss a beat",
  "AI First",
  "GitHub Integration - Your workflow, connected",
  "Local-First",
  "Open Source - Full transparency",
  "Enterprise Ready - Scale with confidence",
  "Lightweight - Fast and responsive",
  "Rich Collaboration",
  "Fair Pricing",
  "Secure Messaging",
  "Scalable for any Team",
];
---

<section id="hero" class="w-full relative">
  <div class="relative flex flex-col items-center w-full px-6">
    <div class="absolute inset-0">
      <div
        class="absolute inset-0 -z-10 h-[600px] md:h-[800px] w-full [background:radial-gradient(125%_125%_at_50%_10%,var(--background)_40%,var(--secondary)_100%)] rounded-b-xl"
      >
      </div>
    </div>
    <div
      class="relative z-10 pt-32 max-w-4xl mx-auto h-full w-full flex flex-col gap-10 items-center justify-center"
    >
      <p
        class="border border-border bg-accent rounded-full text-sm h-8 px-3 flex items-center gap-2"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="dark:fill-white fill-[#364153]"
          aria-hidden="true"
        >
          <path
            d="M7.62758 1.09876C7.74088 1.03404 7.8691 1 7.99958 1C8.13006 1 8.25828 1.03404 8.37158 1.09876L13.6216 4.09876C13.7363 4.16438 13.8316 4.25915 13.8979 4.37347C13.9642 4.48779 13.9992 4.6176 13.9992 4.74976C13.9992 4.88191 13.9642 5.01172 13.8979 5.12604C13.8316 5.24036 13.7363 5.33513 13.6216 5.40076L8.37158 8.40076C8.25828 8.46548 8.13006 8.49952 7.99958 8.49952C7.8691 8.49952 7.74088 8.46548 7.62758 8.40076L2.37758 5.40076C2.26287 5.33513 2.16753 5.24036 2.10123 5.12604C2.03492 5.01172 2 4.88191 2 4.74976C2 4.6176 2.03492 4.48779 2.10123 4.37347C2.16753 4.25915 2.26287 4.16438 2.37758 4.09876L7.62758 1.09876Z"
          ></path>
          <path
            d="M2.56958 7.23928L2.37758 7.34928C2.26287 7.41491 2.16753 7.50968 2.10123 7.624C2.03492 7.73831 2 7.86813 2 8.00028C2 8.13244 2.03492 8.26225 2.10123 8.37657C2.16753 8.49089 2.26287 8.58566 2.37758 8.65128L7.62758 11.6513C7.74088 11.716 7.8691 11.75 7.99958 11.75C8.13006 11.75 8.25828 11.716 8.37158 11.6513L13.6216 8.65128C13.7365 8.58573 13.8321 8.49093 13.8986 8.3765C13.965 8.26208 14 8.13211 14 7.99978C14 7.86745 13.965 7.73748 13.8986 7.62306C13.8321 7.50864 13.7365 7.41384 13.6216 7.34828L13.4296 7.23828L9.11558 9.70328C8.77568 9.89744 8.39102 9.99956 7.99958 9.99956C7.60814 9.99956 7.22347 9.89744 6.88358 9.70328L2.56958 7.23928Z"
          ></path>
          <path
            d="M2.37845 10.5993L2.57045 10.4893L6.88445 12.9533C7.22435 13.1474 7.60901 13.2496 8.00045 13.2496C8.39189 13.2496 8.77656 13.1474 9.11645 12.9533L13.4305 10.4883L13.6225 10.5983C13.7374 10.6638 13.833 10.7586 13.8994 10.8731C13.9659 10.9875 14.0009 11.1175 14.0009 11.2498C14.0009 11.3821 13.9659 11.5121 13.8994 11.6265C13.833 11.7409 13.7374 11.8357 13.6225 11.9013L8.37245 14.9013C8.25915 14.966 8.13093 15 8.00045 15C7.86997 15 7.74175 14.966 7.62845 14.9013L2.37845 11.9013C2.2635 11.8357 2.16795 11.7409 2.10148 11.6265C2.03501 11.5121 2 11.3821 2 11.2498C2 11.1175 2.03501 10.9875 2.10148 10.8731C2.16795 10.7586 2.2635 10.6638 2.37845 10.5983V10.5993Z"
          ></path>
        </svg>
        {hero.badge}
      </p>
      <div class="flex flex-col items-center justify-center gap-5">
        <h1
          class="text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-medium tracking-tighter text-balance text-center text-primary"
        >
          {hero.title}
        </h1>
        <p
          class="text-base md:text-lg text-center text-muted-foreground font-medium text-balance leading-relaxed tracking-tight"
        >
          {hero.description}
        </p>
      </div>
      <div class="flex items-center gap-2.5 flex-wrap justify-center">
        <a
          href={hero.cta.primary.href}
          class="bg-secondary h-9 flex items-center justify-center text-sm font-normal tracking-wide rounded-full text-primary-foreground dark:text-secondary-foreground w-32 px-4 shadow-[inset_0_1px_2px_rgba(255,255,255,0.25),0_3px_3px_-1.5px_rgba(16,24,40,0.06),0_1px_1px_rgba(16,24,40,0.08)] border border-white/[0.12] hover:bg-secondary/80 transition-colors ease-out active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
        >
          {hero.cta.primary.text}
        </a>
        <GitHubCTAButton
          client:visible
          href={hero.cta.secondary.href}
          text={hero.cta.secondary.text}
        />
      </div>
    </div>
  </div>

  <!-- Feature Marquee -->
  <div class="w-full pt-18 px-6 pb-4 max-w-7xl mx-auto">
    <Marquee pauseOnHover className="[--duration:30s]" client:visible>
      {
        features.map((feature) => (
          <span class="text-sm text-muted-foreground font-medium px-4 flex items-center gap-3 cursor-default hover:text-foreground transition-colors">
            <span class="size-1.5 rounded-full bg-secondary shrink-0" />
            {feature}
          </span>
        ))
      }
    </Marquee>
  </div>

  <!-- Hero Video/Image Section -->
  <div class="relative px-6">
    <div
      class="relative size-full rounded-2xl overflow-hidden shadow-2xl shadow-black/20 ring-1 ring-black/10 dark:ring-white/10"
    >
      <!-- Product image shown instead of video -->
      <img
        src="/features/desktop-app.webp"
        alt="Hazel open source team chat platform - real-time messaging interface with channels and direct messages"
        width="1920"
        height="1080"
        class="w-full"
        loading="eager"
      />

      <!--
        Video code preserved for future use:
        To enable, uncomment the import above and use:

        <HeroVideoDialog
          client:visible
          className="block dark:hidden"
          animationStyle="from-center"
          videoSrc="https://www.youtube.com/embed/qh3NGpYRG3I?si=4rb-zSdDkVK9qxxb"
          thumbnailAlt="Hero Video"
        />
        <HeroVideoDialog
          client:visible
          className="hidden dark:block"
          animationStyle="from-center"
          videoSrc="https://www.youtube.com/embed/qh3NGpYRG3I?si=4rb-zSdDkVK9qxxb"
          thumbnailAlt="Hero Video"
        />
      -->
    </div>
  </div>
</section>
