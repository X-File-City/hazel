---
// Changelog hero section with editorial aesthetic
---

<section class="w-full relative">
  <div class="relative flex flex-col items-center w-full px-6">
    <div class="absolute inset-0">
      <div
        class="absolute inset-0 -z-10 h-[420px] w-full [background:radial-gradient(125%_125%_at_50%_10%,var(--background)_40%,var(--secondary)_100%)] rounded-b-xl opacity-50"
      >
      </div>
    </div>
    <div
      class="relative z-10 pt-32 pb-20 max-w-3xl mx-auto h-full w-full flex flex-col gap-6 items-center justify-center"
    >
      <!-- Badge -->
      <p
        class="border border-border bg-accent/80 backdrop-blur-sm rounded-full text-sm h-9 px-4 flex items-center gap-2 font-mono text-muted-foreground"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-4"
        >
          <path d="M12 8V4H8"></path>
          <rect width="16" height="12" x="4" y="8" rx="2"></rect>
          <path d="M2 14h2"></path>
          <path d="M20 14h2"></path>
          <path d="M15 13v2"></path>
          <path d="M9 13v2"></path>
        </svg>
        Product Updates
      </p>

      <!-- Title & Description -->
      <div class="flex flex-col items-center justify-center gap-4">
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tighter text-balance text-center text-primary"
        >
          Changelog
        </h1>
        <p
          class="text-base md:text-lg text-center text-muted-foreground font-medium text-balance leading-relaxed tracking-tight max-w-xl"
        >
          New features, improvements, and fixes. Stay up to date with everything
          happening in Hazel.
        </p>
      </div>

      <!-- Action Links -->
      <div class="flex items-center gap-3 flex-wrap justify-center mt-2">
        <a
          href="https://github.com/hazelchat/hazel/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="h-10 flex items-center justify-center gap-2 px-5 text-sm font-medium tracking-wide text-primary rounded-full transition-all ease-out duration-200 active:scale-95 bg-background border border-border hover:border-muted-foreground/50 hover:bg-accent/50"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
          View on GitHub
        </a>
        <a
          href="/rss/changelog.xml"
          class="h-10 flex items-center justify-center gap-2 px-5 text-sm font-medium tracking-wide text-primary rounded-full transition-all ease-out duration-200 active:scale-95 bg-background border border-border hover:border-muted-foreground/50 hover:bg-accent/50"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
          RSS Feed
        </a>
      </div>
    </div>
  </div>
</section>
