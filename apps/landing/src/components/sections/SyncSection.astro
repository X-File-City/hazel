---
import SectionHeader from "@/components/SectionHeader.astro";
import { SyncSection as SyncSectionReact } from "@/components/react/SyncFlowAnimation";
---

<section
  id="sync"
  class="flex flex-col items-center justify-center w-full relative px-5 md:px-10"
>
  <div class="border-x mx-5 md:mx-10 relative w-full">
    <!-- Decorative borders -->
    <div class="absolute top-0 -left-4 md:-left-14 h-full w-4 md:w-14 text-primary/5 bg-[size:10px_10px] [background-image:repeating-linear-gradient(315deg,currentColor_0_1px,#0000_0_50%)]"></div>
    <div class="absolute top-0 -right-4 md:-right-14 h-full w-4 md:w-14 text-primary/5 bg-[size:10px_10px] [background-image:repeating-linear-gradient(315deg,currentColor_0_1px,#0000_0_50%)]"></div>

    <!-- Section Header -->
    <SectionHeader>
      <h2 class="text-3xl md:text-4xl font-medium tracking-tighter text-center text-balance">
        Keep Every Conversation Connected
      </h2>
      <p class="text-muted-foreground text-center text-balance font-medium">
        Seamlessly sync messages, threads, and reactions between Discord, Slack, and Hazel.
      </p>
    </SectionHeader>

    <!-- Sync Animation and Content -->
    <div class="py-8 md:py-12">
      <SyncSectionReact client:visible />
    </div>
  </div>
</section>
