---
import { Icons } from "@/components/react/Icons";
import { FlickeringGrid } from "@/components/react/FlickeringGrid";
import { siteConfig } from "@/lib/config";
---

<footer id="footer" class="w-full pb-0">
  <div
    class="flex flex-col p-10 md:flex-row md:items-center md:justify-between"
  >
    <div class="mx-0 flex max-w-xs flex-col items-start justify-start gap-y-5">
      <a href="/" class="flex items-center gap-2">
        <Icons.logo className="size-8" />
        <p class="font-semibold text-primary text-xl">Hazel</p>
      </a>
      <p class="font-medium text-muted-foreground tracking-tight">
        {siteConfig.hero.description}
      </p>
    </div>
    <div class="pt-5 md:w-1/2">
      <div
        class="flex flex-col items-start justify-start gap-y-5 md:flex-row md:items-center md:justify-between lg:pl-10"
      >
        {
          siteConfig.footerLinks.map((column, columnIndex) => (
            <ul class="flex flex-col gap-y-2">
              <li class="mb-2 font-semibold text-primary text-sm">
                {column.title}
              </li>
              {column.links.map((link) => (
                <li class="group inline-flex cursor-pointer items-center justify-start gap-1 text-[15px]/snug text-muted-foreground">
                  <a href={link.url} class="flex items-center gap-1.5">
                    {link.title}
                  </a>
                  <div class="flex size-4 translate-x-0 transform items-center justify-center rounded border border-border opacity-0 transition-all duration-300 ease-out group-hover:translate-x-1 group-hover:opacity-100">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-4 w-4"
                    >
                      <path d="m9 18 6-6-6-6" />
                    </svg>
                  </div>
                </li>
              ))}
            </ul>
          ))
        }
      </div>
    </div>
  </div>
  <div class="relative z-0 mt-24 h-48 w-full md:h-64">
    <div
      class="absolute inset-0 z-10 bg-gradient-to-t from-40% from-transparent to-background"
    >
    </div>
    <div class="absolute inset-0 mx-6">
      <FlickeringGrid
        text="Empower your Team"
        fontSize={90}
        className="h-full w-full"
        squareSize={2}
        gridGap={3}
        color="#6B7280"
        maxOpacity={0.3}
        flickerChance={0.1}
        client:visible
      />
    </div>
  </div>
</footer>

<script>
  // Handle responsive text for FlickeringGrid
  // This is a simple approach - you could also make FlickeringGrid accept props dynamically
  const updateFlickeringText = () => {
    const isTablet = window.matchMedia("(max-width: 1024px)").matches;
    // You might need to update the FlickeringGrid component to accept dynamic text
    // For now, this is a placeholder for responsive behavior
  };

  if (typeof window !== "undefined") {
    updateFlickeringText();
    window.addEventListener("resize", updateFlickeringText);
  }
</script>
