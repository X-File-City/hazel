---
import SectionHeader from "@/components/SectionHeader.astro";
import type { IntegrationFeature } from "@/content/config";

interface Props {
	features: IntegrationFeature[];
	integrationName: string;
}

const { features, integrationName } = Astro.props;

// Icon mapping - simple geometric icons for each feature
const iconPaths: Record<string, string> = {
	sync: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15",
	channel:
		"M7 20l4-16m2 16l4-16M6 9h14M4 15h14",
	message:
		"M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
	file: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
	users: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z",
	bolt: "M13 10V3L4 14h7v7l9-11h-7z",
	shield:
		"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
	check: "M5 13l4 4L19 7",
	default:
		"M13 10V3L4 14h7v7l9-11h-7z",
};

const getIconPath = (icon?: string): string => {
	if (!icon) return iconPaths.default;
	return iconPaths[icon.toLowerCase()] || iconPaths.default;
};
---

<section id="features" class="w-full relative">
	<div class="flex flex-col items-center justify-center px-5 md:px-10">
		<div class="border-x relative w-full max-w-6xl">
			<!-- Decorative side patterns -->
			<div
				class="absolute top-0 -left-4 md:-left-14 h-full w-4 md:w-14 text-primary/[0.03] bg-[size:10px_10px] [background-image:repeating-linear-gradient(315deg,currentColor_0_1px,#0000_0_50%)]"
			>
			</div>
			<div
				class="absolute top-0 -right-4 md:-right-14 h-full w-4 md:w-14 text-primary/[0.03] bg-[size:10px_10px] [background-image:repeating-linear-gradient(315deg,currentColor_0_1px,#0000_0_50%)]"
			>
			</div>

			<SectionHeader>
				<h2
					class="text-3xl md:text-4xl font-semibold tracking-tight text-center text-balance pb-1 text-primary"
				>
					Key Features
				</h2>
				<p class="text-muted-foreground text-center text-balance font-medium">
					What you can do with {integrationName} in Hazel
				</p>
			</SectionHeader>

			<!-- Features Grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 p-6 md:p-10">
				{
					features.map((feature, index) => (
						<div
							class="group relative flex flex-col gap-4 p-6 rounded-2xl border border-border/50 bg-gradient-to-b from-accent/30 to-transparent hover:border-border hover:shadow-lg hover:shadow-secondary/5 transition-all duration-300"
							style={`animation-delay: ${index * 50}ms`}
						>
							<!-- Icon -->
							<div class="relative">
								<div class="size-11 rounded-xl bg-secondary/10 border border-secondary/20 flex items-center justify-center text-secondary group-hover:bg-secondary/20 group-hover:scale-105 transition-all duration-300">
									<svg
										class="size-5"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
										stroke-width="1.5"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<path d={getIconPath(feature.icon)} />
									</svg>
								</div>
							</div>

							<!-- Content -->
							<div class="flex flex-col gap-2">
								<h3 class="text-base font-semibold tracking-tight text-primary group-hover:text-secondary transition-colors duration-300">
									{feature.title}
								</h3>
								<p class="text-sm text-muted-foreground leading-relaxed">
									{feature.description}
								</p>
							</div>

							<!-- Hover accent line -->
							<div class="absolute bottom-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-secondary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>
