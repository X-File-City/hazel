---
import { SystemRequirements } from "@/components/react/SystemRequirements";
---

<section id="system-requirements" class="w-full py-16 px-6">
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-foreground">
        System Requirements
      </h2>
      <p class="mt-3 text-muted-foreground">
        Make sure your system meets these requirements for the best experience.
      </p>
    </div>

    <div class="border border-border rounded-xl p-6 bg-accent/30">
      <SystemRequirements client:visible />
    </div>
  </div>
</section>
