---
// App Preview Section - displays a screenshot of the desktop app
// Replace the placeholder image with an actual screenshot when available
---

<section id="app-preview" class="w-full py-16 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-foreground">
        Built for your desktop
      </h2>
      <p class="mt-3 text-muted-foreground max-w-xl mx-auto">
        A native experience that feels right at home on macOS, Windows, and Linux.
      </p>
    </div>

    <!-- Screenshot container with device frame styling -->
    <div class="relative">
      <!-- Decorative glow -->
      <div class="absolute -inset-4 bg-gradient-to-r from-secondary/20 via-secondary/10 to-secondary/20 rounded-3xl blur-2xl opacity-50"></div>

      <!-- Screenshot wrapper -->
      <div class="relative rounded-xl overflow-hidden border border-border bg-accent/30 shadow-2xl shadow-black/20">
        <!-- Window controls (macOS style) -->
        <div class="flex items-center gap-2 px-4 py-3 bg-accent/50 border-b border-border">
          <div class="flex items-center gap-1.5">
            <div class="size-3 rounded-full bg-[#ff5f57]"></div>
            <div class="size-3 rounded-full bg-[#febc2e]"></div>
            <div class="size-3 rounded-full bg-[#28c840]"></div>
          </div>
          <div class="flex-1 text-center">
            <span class="text-xs text-muted-foreground font-medium">Hazel</span>
          </div>
          <div class="w-12"></div>
        </div>

        <!-- Screenshot placeholder - replace src with actual screenshot -->
        <div class="aspect-[16/10] bg-background flex items-center justify-center">
          <!-- Placeholder content - replace with actual image -->
          <img
            src="/features/desktop-app.webp"
            alt="Hazel Desktop application interface showing team chat and collaboration features"
            width="1920"
            height="1200"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
