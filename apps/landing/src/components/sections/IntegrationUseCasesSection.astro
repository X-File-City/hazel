---
import type { IntegrationUseCase } from "@/content/config";

interface Props {
	useCases: IntegrationUseCase[];
	integrationName: string;
}

const { useCases, integrationName } = Astro.props;
---

<section id="use-cases" class="w-full relative bg-accent/20">
	<!-- Subtle top border gradient -->
	<div
		class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
	>
	</div>

	<div class="flex flex-col items-center justify-center px-5 md:px-10">
		<div class="relative w-full max-w-6xl py-16 md:py-24">
			<!-- Section header -->
			<div class="flex flex-col items-center gap-4 mb-16 text-center">
				<div
					class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-background border border-border"
				>
					<span class="text-xs font-semibold uppercase tracking-widest text-secondary">
						Use Cases
					</span>
				</div>
				<h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-primary">
					How teams use {integrationName}
				</h2>
				<p class="text-muted-foreground max-w-xl">
					Real-world scenarios where this integration shines
				</p>
			</div>

			<!-- Use Cases with alternating layout -->
			<div class="flex flex-col gap-20 md:gap-28">
				{
					useCases.map((useCase, index) => (
						<div
							class={`flex flex-col gap-8 items-center ${index % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"}`}
						>
							<!-- Image/Visual -->
							{useCase.image ? (
								<div class="flex-1 w-full">
									<div class="relative group">
										{/* Decorative frame */}
										<div class="absolute -inset-3 rounded-2xl bg-gradient-to-br from-secondary/20 via-transparent to-secondary/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-xl" />
										<div class="relative rounded-2xl overflow-hidden border border-border/50 shadow-2xl shadow-black/10 ring-1 ring-white/5">
											<img
												src={useCase.image}
												alt={useCase.title}
												class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-[1.02]"
												loading="lazy"
											/>
										</div>
									</div>
								</div>
							) : (
								<div class="flex-1 w-full">
									<div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-secondary/5 via-accent/50 to-secondary/10 border border-border/50 flex items-center justify-center">
										<div class="flex flex-col items-center gap-4 text-muted-foreground/50">
											<svg
												class="size-16"
												fill="none"
												viewBox="0 0 24 24"
												stroke="currentColor"
												stroke-width="1"
											>
												<path
													stroke-linecap="round"
													stroke-linejoin="round"
													d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
												/>
											</svg>
										</div>
									</div>
								</div>
							)}

							<!-- Content -->
							<div
								class={`flex-1 flex flex-col gap-5 ${useCase.image ? "" : "max-w-xl text-center mx-auto"}`}
							>
								{/* Use case number badge */}
								<div class="flex items-center gap-3">
									<span class="inline-flex items-center justify-center size-8 rounded-full bg-secondary/10 border border-secondary/20 text-secondary text-sm font-bold">
										{index + 1}
									</span>
									<div class="h-px flex-1 bg-gradient-to-r from-border to-transparent max-w-24" />
								</div>

								<h3 class="text-2xl md:text-3xl font-semibold tracking-tight text-primary leading-tight">
									{useCase.title}
								</h3>

								<p class="text-muted-foreground leading-relaxed text-base md:text-lg">
									{useCase.description}
								</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>

	<!-- Subtle bottom border gradient -->
	<div
		class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
	>
	</div>
</section>
