---

---

<section
  id="testimonial"
  class="relative flex flex-col items-center justify-center w-full py-24 px-6 overflow-hidden"
>
  <!-- Subtle background gradient -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-transparent via-accent/30 to-transparent"
  >
  </div>

  <!-- Content container -->
  <div class="relative max-w-4xl mx-auto">
    <!-- Large decorative quote mark -->
    <svg
      class="absolute -top-8 -left-4 md:-left-12 w-20 h-20 md:w-32 md:h-32 text-secondary/20"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
      ></path>
    </svg>

    <blockquote class="relative z-10">
      <!-- Quote text -->
      <p
        class="text-xl md:text-2xl lg:text-3xl text-primary leading-relaxed tracking-tight font-medium text-center md:text-left"
      >
        "Hazel has been an amazing upgrade for our workflow, allowing us to
        escape the clutches of Slack and easily integrate our network of
        coaches, partners and AI agents into it, which made it easy to scale our
        business without the cost burdens that come with it."
      </p>

      <!-- Author section -->
      <footer
        class="mt-10 flex flex-col md:flex-row items-center md:items-start gap-4"
      >
        <!-- Avatar -->
        <img
          src="https://ca.slack-edge.com/T01SCLK3KR9-U073ATJLHEZ-62230b970771-512"
          alt="Ian Rumac"
          class="size-14 rounded-full object-cover shrink-0"
        />

        <div class="text-center md:text-left">
          <cite class="not-italic font-semibold text-lg text-primary block">
            Ian Rumac
          </cite>
          <div
            class="flex items-center justify-center md:justify-start gap-2 text-muted-foreground"
          >
            <span>CEO</span>
            <span class="text-border">•</span>
            <a
              href="https://www.gymscore.ai/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 font-medium text-primary hover:text-secondary transition-colors"
            >
              <img
                src="/logos/gymscore.svg"
                alt="Gymscore"
                class="h-5 w-auto rounded"
              />
              Gymscore
            </a>
          </div>
        </div>
      </footer>
    </blockquote>

    <!-- Closing decorative quote mark -->
    <svg
      class="absolute -bottom-4 -right-4 md:-right-8 w-16 h-16 md:w-24 md:h-24 text-secondary/20 rotate-180"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
      ></path>
    </svg>
  </div>
</section>
