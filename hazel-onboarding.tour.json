            { "path": "packages/integrations", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "supporting-services",
      "title": "Supporting Services",
      "description": "Beyond the three core apps, Hazel includes several specialized services: an Electric SQL proxy for real-time sync validation, a bot gateway for third-party bot integrations, a link preview worker, a desktop app (Tauri), and a documentation site.",
      "focusDirectory": "apps",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "core-apps",
          "name": "Core Apps",
          "color": "#6938EF",
