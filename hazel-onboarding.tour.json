            { "path": "packages/domain", "type": "directory" },
            { "path": "packages/db", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "infra-packages",
          "name": "Infrastructure",
          "color": "#6366f1",
          "items": [
