    {
      "id": "full-picture",
      "title": "The Full Picture",
      "description": "That's Hazel Chat — a modern team communication platform built with React 19, Effect-TS, Bun, and PostgreSQL. The monorepo structure keeps apps and packages cleanly separated while shared contracts in packages/domain/ ensure end-to-end type safety. Explore the codebase to see how it all connects.",
      "focusDirectory": "",
      "colorMode": "git",
