{
	"name": "@hazel-chat/bot-sdk",
	"version": "0.1.0",
	"description": "Official SDK for building bots for Hazel Chat. Built with Effect-TS.",
	"keywords": [
		"bot",
		"chat",
		"effect",
		"effect-ts",
		"hazel",
		"sdk"
	],
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"import": {
				"types": "./src/index.ts",
				"default": "./src/index.ts"
			}
		},
		"./config": {
			"import": {
				"types": "./src/config.ts",
				"default": "./src/config.ts"
			}
		},
		"./auth": {
			"import": {
				"types": "./src/auth.ts",
				"default": "./src/auth.ts"
			}
		},
		"./errors": {
			"import": {
				"types": "./src/errors.ts",
				"default": "./src/errors.ts"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsdown",
		"prepublishOnly": "GENERATE_DTS=1 bun run build"
	},
	"devDependencies": {
		"@effect/language-service": "catalog:effect",
		"@effect/opentelemetry": "catalog:effect",
		"@effect/platform": "catalog:effect",
		"@effect/platform-bun": "catalog:effect",
		"@effect/rpc": "catalog:effect",
		"@hazel/actors": "workspace:*",
		"@hazel/domain": "workspace:*",
		"@hazel/effect-bun": "workspace:*",
		"@hazel/schema": "workspace:*",
		"@types/bun": "1.3.9",
		"effect": "catalog:effect",
		"jose": "^6.1.3",
		"msw": "^2.7.0",
		"rivetkit": "2.1.6",
		"tsdown": "^0.20.3",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@effect/opentelemetry": ">=0.61.0",
		"@effect/platform": ">=0.94.0",
		"@effect/platform-bun": ">=0.87.0",
		"@effect/rpc": ">=0.73.0",
		"@effect/workflow": ">=0.16.0",
		"effect": ">=3.19.0",
		"jose": ">=6.0.0",
		"rivetkit": ">=2.0.0"
	},
	"peerDependenciesMeta": {
		"@effect/opentelemetry": {
			"optional": true
		},
		"jose": {
			"optional": true
		},
		"rivetkit": {
			"optional": true
		},
		"@effect/workflow": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.2.0"
	}
}
