# Bot Authentication Token
# Get this from your organization's bot settings
BOT_TOKEN=your_bot_token_here

# Backend API URL (optional)
# Defaults to https://api.hazel.sh in production
BACKEND_URL=http://localhost:3003

# Gateway URL (recommended)
# Inbound bot events are delivered over websocket from the gateway service
GATEWAY_URL=http://localhost:3034

# Actors (Rivet) URL (optional)
# Defaults to Rivet BYOC production endpoint
# Also checks RIVET_PUBLIC_ENDPOINT env var as fallback
ACTORS_URL=http://localhost:6420
